CFLAGS = -O3 -g -Wall -fstrict-aliasing -std=c99 -I ../src

all: test_1_parse test_1_init test_1_add_v test_1_add_e test_1_get_degree test_1_set_adj test_1_v_distance
		
graph:graph.c 
	$(CC) $(CFLAGS) graph.c -o $@

